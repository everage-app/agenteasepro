DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
JWT_SECRET=replace-with-secure-secret-min-32-characters
NODE_ENV=production
OPENAI_API_KEY=
AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=12000
OPENAI_MAX_RETRIES=1

# Encryption key for sensitive data (REQUIRED in production - must be exactly 32 characters)
ENCRYPTION_KEY=replace-with-32-character-key!!

# App URLs
PUBLIC_APP_URL=https://your-app-domain.com
APP_BASE_URL=https://your-app-domain.com

# Stripe Configuration (for billing)
# Use environment variables (NEVER commit live keys).
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Create a recurring monthly Price in Stripe for $49.99/month and put its Price ID here.
STRIPE_PRICE_ID=price_your_49_99_monthly_price_id

# SendGrid (for email notifications)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Google Calendar Integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook/Instagram Integration (uses same app)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# LinkedIn Integration
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Owner admin access (optional - for internal admin panel)
AGENTEASE_OWNER_EMAIL=
AGENTEASE_OWNER_ID=

# Property APIs (optional)
RAPIDAPI_KEY=
RENTCAST_API_KEY=

# Demo login (set to false in production)
ALLOW_DEV_LOGIN=false
ALLOW_DEMO_LOGIN=true
DEMO_LOGIN_EMAIL=demo@agentease.com
