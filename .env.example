DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/YOUR_DB_NAME?connection_limit=5"
# Optional on Heroku if DATABASE_CONNECTION_POOL_URL is configured and verified with Prisma/PgBouncer.
AEP_USE_DATABASE_POOL_URL="false"
JWT_SECRET="replace_with_at_least_32_random_characters"
NODE_ENV="development"

# AI
OPENAI_API_KEY="replace_with_openai_api_key"
AI_PROVIDER="openai"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_TIMEOUT_MS="30000"
OPENAI_MAX_RETRIES="2"

# Encryption
ENCRYPTION_KEY="replace_with_32_byte_base64_or_hex_key"

# Public URLs
PUBLIC_APP_URL="http://localhost:5174"
APP_BASE_URL="http://localhost:5174"

# Stripe
STRIPE_SECRET_KEY="replace_with_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="replace_with_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="replace_with_stripe_webhook_secret"
STRIPE_PRICE_ID="replace_with_stripe_price_id"

# SendGrid
SENDGRID_API_KEY="replace_with_sendgrid_api_key"
SENDGRID_FROM_EMAIL="no-reply@example.com"
ESIGN_TRACKING_EMAIL="esign@example.com"
SENDGRID_ALLOWED_FROM_DOMAINS="example.com"

# OAuth
GOOGLE_CLIENT_ID="replace_with_google_oauth_client_id"
GOOGLE_CLIENT_SECRET="replace_with_google_oauth_client_secret"
FACEBOOK_APP_ID="replace_with_facebook_app_id"
FACEBOOK_APP_SECRET="replace_with_facebook_app_secret"
LINKEDIN_CLIENT_ID="replace_with_linkedin_client_id"
LINKEDIN_CLIENT_SECRET="replace_with_linkedin_client_secret"

# Internal owner bootstrap
AGENTEASE_MASTER_OWNER_EMAIL="brysen@agenteasepro.com"
AGENTEASE_OWNER_EMAIL="owner-admin@example.com"
AGENTEASE_OWNER_ADMIN_EMAILS="owner-admin@example.com,ops-admin@example.com"
AGENTEASE_OWNER_ID="replace_with_owner_agent_id"

# Optional property data providers
RAPIDAPI_KEY="replace_with_rapidapi_key"
RENTCAST_API_KEY="replace_with_rentcast_api_key"

# Local/demo login controls
ALLOW_DEV_LOGIN="true"
ALLOW_DEMO_LOGIN="true"
DEMO_LOGIN_EMAIL="demo@example.com"
