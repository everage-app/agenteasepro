generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AgentStatus {
  ACTIVE
  SUSPENDED
  REVOKED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BillingMode {
  FREE
  STANDARD
  CUSTOM
}

enum SupportCategory {
  GENERAL
  SUGGESTION
  BILLING
  BUG
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InternalStaffRole {
  OWNER
  ADMIN
  SUPPORT
  BILLING
  SALES
  PRODUCT
  ENGINEERING
  READ_ONLY
}

model Agent {
  id                      String                    @id @default(uuid())
  email                   String                    @unique
  name                    String
  passwordHash            String?
  resetToken              String?
  resetTokenExpiry        DateTime?
  emailVerified           Boolean                   @default(false)
  emailVerifyToken        String?
  emailVerifyExpiry       DateTime?
  status                  AgentStatus               @default(ACTIVE)
  subscriptionStatus      SubscriptionStatus        @default(TRIAL)
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  billingMode             BillingMode               @default(STANDARD)
  billingCustomPriceCents Int?
  billingAccessOverride   Boolean                   @default(false)
  termsAcceptedAt         DateTime?
  privacyAcceptedAt       DateTime?
  termsVersionAccepted    String?
  privacyVersionAccepted  String?
  termsUrlAccepted        String?
  privacyUrlAccepted      String?
  legalAcceptedIp         String?
  legalAcceptedUserAgent  String?
  brokerageName           String?
  licenseNumber           String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  clients                 Client[]
  properties              Property[]
  deals                   Deal[]
  listings                Listing[]
  marketingBlasts         MarketingBlast[]
  marketingDeliveryLogs   MarketingDeliveryLog[]
  marketingEmailEvents    MarketingEmailEvent[]
  dealEvents              DealEvent[]
  tasks                   Task[]
  mlsListings             MlsListing[]
  channelConnections      AgentChannelConnection[]
  dailyActivities         DailyActivity[]
  automationRules         AutomationRule[]
  googleCalendar          GoogleCalendarConnection?
  idxConnection           IdxConnection?
  aiSettings              AgentAiSettings?
  profileSettings         AgentProfileSettings?
  notificationPrefs       AgentNotificationPrefs?
  landingPages            LandingPage[]
  leads                   Lead[]
  internalEvents          InternalEvent[]
  internalErrors          InternalError[]
  supportRequests         SupportRequest[]          @relation("SupportOwner")
  assignedSupportRequests SupportRequest[]          @relation("SupportAssignment")
  internalStaffProfile    InternalStaff?
  internalAuditLogs       InternalAuditLog[]        @relation("InternalAuditActor")
  teamMemberships         TeamMember[]
  revokedTokens           RevokedToken[]
  loginAttemptRecords     LoginAttemptRecord[]
  sequenceEnrollments     SequenceEnrollment[]
  sequences               Sequence[]
  oauthStates             OAuthState[]
  outboundWebhooks        OutboundWebhook[]
  webhookSubscriptions    WebhookSubscription[]
  contactEmailTemplates   ContactEmailTemplate[]
  smartLists              SmartList[]
  teamId                  String?
  team                    Team?                     @relation("AgentPrimaryTeam", fields: [teamId], references: [id])
  brokerageId             String?
  brokerage               Brokerage?                @relation(fields: [brokerageId], references: [id])

  @@index([createdAt], map: "Agent_createdAt_idx")
  @@index([status, createdAt], map: "Agent_status_createdAt_idx")
  @@index([subscriptionStatus, createdAt], map: "Agent_subscriptionStatus_createdAt_idx")
  @@index([teamId], map: "Agent_teamId_idx")
  @@index([brokerageId], map: "Agent_brokerageId_idx")
}

model SupportRequest {
  id                String          @id @default(uuid())
  agentId           String
  agent             Agent           @relation("SupportOwner", fields: [agentId], references: [id], onDelete: Cascade)
  assignedToAgentId String?
  assignedToAgent   Agent?          @relation("SupportAssignment", fields: [assignedToAgentId], references: [id], onDelete: SetNull)
  category          SupportCategory @default(GENERAL)
  subject           String
  message           String
  status            SupportStatus   @default(OPEN)
  priority          SupportPriority @default(MEDIUM)
  pagePath          String?
  pageUrl           String?
  userAgent         String?
  meta              Json?
  internalNotes     String?
  firstResponseAt   DateTime?
  dueAt             DateTime?
  resolvedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([agentId])
  @@index([assignedToAgentId, status])
  @@index([status, priority, createdAt])
  @@index([dueAt])
}

model InternalStaff {
  id           String            @id @default(cuid())
  agentId      String            @unique
  agent        Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  role         InternalStaffRole @default(READ_ONLY)
  title        String?
  active       Boolean           @default(true)
  notes        String?
  lastAccessAt DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([role, active])
}

model InternalAuditLog {
  id           String   @id @default(cuid())
  actorAgentId String?
  actor        Agent?   @relation("InternalAuditActor", fields: [actorAgentId], references: [id], onDelete: SetNull)
  action       String
  targetType   String
  targetId     String?
  summary      String
  before       Json?
  after        Json?
  reason       String?
  requestId    String?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([actorAgentId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
}

model AgentProfileSettings {
  id                      String    @id @default(cuid())
  agentId                 String    @unique
  agent                   Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  firstName               String?
  lastName                String?
  phone                   String?
  licenseNumber           String?
  licenseSuffix           String?
  licenseState            String?
  licenseExpiry           DateTime?
  narMemberId             String?
  timezone                String    @default("America/Denver")
  signatureBlock          String?
  photoUrl                String?
  yearsExperience         Int?
  specializations         String?
  bio                     String?
  // Branding
  brokerageName           String?
  brokerageLogoUrl        String?
  brokerageLogoWidth      Int       @default(260)
  brokerageLogoBackground String    @default("CARD")
  brokerageAddress        String?
  brokeragePhone          String?
  officeAddress           String?
  brokerageLicense        String?
  brandColor              String    @default("#3B82F6")
  accentColor             String    @default("#06B6D4")
  logoUrl                 String?
  websiteUrl              String?
  googleAnalyticsId       String?
  facebookUrl             String?
  instagramUrl            String?
  linkedinUrl             String?
  emailFooter             String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model AgentNotificationPrefs {
  id                 String   @id @default(cuid())
  agentId            String   @unique
  agent              Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  deadlineEmails     Boolean  @default(true)
  dailyPlanEnabled   Boolean  @default(true)
  dailyPlanTime      String   @default("07:00")
  inAppBanners       Boolean  @default(true)
  signatureAlerts    Boolean  @default(true)
  documentComplete   Boolean  @default(true)
  marketingSummaries Boolean  @default(true)
  quietHoursStart    String   @default("22:00")
  quietHoursEnd      String   @default("07:00")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AgentAiSettings {
  id        String            @id @default(cuid())
  agentId   String            @unique
  agent     Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  level     AiAssistanceLevel @default(MEDIUM)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

enum AiAssistanceLevel {
  OFF
  LOW
  MEDIUM
  HIGH
}

enum ReferralRank {
  A
  B
  C
}

enum ClientRole {
  BUYER
  SELLER
  BOTH
  OTHER
}

enum ClientStage {
  NEW_LEAD
  NURTURE
  ACTIVE
  UNDER_CONTRACT
  CLOSED
  PAST_CLIENT
  DEAD
}

enum ClientTemperature {
  HOT
  WARM
  COLD
}

model Property {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  mlsId     String?
  street    String
  city      String
  county    String
  state     String   @default("UT")
  zip       String
  taxId     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deals     Deal[]

  @@index([agentId, createdAt])
  @@index([agentId, mlsId])
}

model Deal {
  id                 String                 @id @default(uuid())
  agentId            String
  agent              Agent                  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title              String
  propertyId         String
  property           Property               @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buyerId            String?
  buyer              Client?                @relation("BuyerDeals", fields: [buyerId], references: [id])
  sellerId           String?
  seller             Client?                @relation("SellerDeals", fields: [sellerId], references: [id])
  status             DealStatus             @default(LEAD)
  offerReferenceDate DateTime
  closedAt           DateTime?
  archivedAt         DateTime?
  archivedReason     String?
  archivedByAgentId  String?
  archiveAfterDays   Int                    @default(180)
  lastActivityAt     DateTime?
  deletedAt          DateTime? // Soft delete
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  repc               Repc?
  addendums          Addendum[]
  signatureEnvelopes SignatureEnvelope[]
  forms              FormInstance[]
  events             DealEvent[]
  tasks              Task[]
  checklists         TransactionChecklist[]
  teamId             String?
  team               Team?                  @relation(fields: [teamId], references: [id])
  brokerageId        String?
  brokerage          Brokerage?             @relation(fields: [brokerageId], references: [id])
  stakeholders       DealStakeholder[]

  @@index([agentId, archivedAt, status])
  @@index([agentId, deletedAt])
  @@index([agentId, status, createdAt], map: "Deal_agentId_status_createdAt_idx")
  @@index([agentId, lastActivityAt], map: "Deal_agentId_lastActivityAt_idx")
  @@index([propertyId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([teamId], map: "Deal_teamId_idx")
  @@index([brokerageId], map: "Deal_brokerageId_idx")
}

enum DealStatus {
  LEAD
  ACTIVE
  OFFER_SENT
  UNDER_CONTRACT
  DUE_DILIGENCE
  FINANCING
  SETTLEMENT_SCHEDULED
  CLOSED
  FELL_THROUGH
}

model Repc {
  id                                    String                @id @default(uuid())
  dealId                                String                @unique
  deal                                  Deal                  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  buyerLegalNames                       String
  sellerLegalNames                      String
  earnestMoneyAmount                    Decimal
  earnestMoneyForm                      String
  additionalEarnestMoneyAmount          Decimal?
  propertyCity                          String
  propertyCounty                        String
  propertyState                         String
  propertyZip                           String
  propertyTaxId                         String
  otherIncludedItems                    String
  excludedItems                         String
  waterRightsIncludedNotes              String?
  waterRightsExcludedNotes              String?
  purchasePrice                         Decimal
  newLoanAmount                         Decimal?
  sellerFinancingAmount                 Decimal?
  cashAtSettlement                      Decimal?
  isSubjectToSaleOfBuyersProperty       Boolean
  buyersPropertyDescription             String?
  possessionTiming                      PossessionTiming
  possessionOffset                      Int?
  capitalImprovementsPayer              PayerType
  capitalImprovementsPayerOther         String?
  changeOfOwnershipFeePayer             PayerType
  changeOfOwnershipFeePayerOther        String?
  sellerCompensationContributionPercent Decimal?
  sellerCompensationContributionFlat    Decimal?
  hasDueDiligenceCondition              Boolean
  hasAppraisalCondition                 Boolean
  hasFinancingCondition                 Boolean
  sellerDisclosureDeadline              DateTime
  dueDiligenceDeadline                  DateTime
  financingAppraisalDeadline            DateTime
  settlementDeadline                    DateTime
  hasHomeWarranty                       Boolean
  homeWarrantyOrderedBy                 HomeWarrantyOrderedBy
  homeWarrantyMaxCost                   Decimal?
  offerExpirationDate                   DateTime
  offerExpirationTime                   String
  offerExpirationMeridiem               Meridiem
  rawJson                               Json
  createdAt                             DateTime              @default(now())
  updatedAt                             DateTime              @updatedAt
}

enum PossessionTiming {
  ON_RECORDING
  HOURS_AFTER_RECORDING
  DAYS_AFTER_RECORDING
}

enum PayerType {
  SELLER
  BUYER
  SPLIT
  OTHER
}

enum HomeWarrantyOrderedBy {
  BUYER
  SELLER
  UNKNOWN
}

enum Meridiem {
  AM
  PM
}

model Addendum {
  id                 String       @id @default(uuid())
  dealId             String
  deal               Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type               AddendumType
  title              String
  body               String
  offerReferenceDate DateTime
  buyerLabel         String
  sellerLabel        String
  propertySummary    String
  expirationDate     DateTime?
  expirationTime     String?
  expirationMeridiem Meridiem?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([dealId])
}

enum AddendumType {
  ADDENDUM
  COUNTEROFFER
}

model Listing {
  id      String  @id @default(uuid())
  agentId String
  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  dealId  String?
  mlsId   String?

  // Address fields
  addressLine1 String
  city         String
  state        String @default("UT")
  zipCode      String

  // Property details
  headline    String
  description String
  price       Int
  beds        Int?
  baths       Float?
  sqft        Int?

  // Images
  primaryImageUrl String?
  heroImageUrl    String?

  // Status & marketing
  status      ListingStatus @default(ACTIVE)
  isFeatured  Boolean       @default(false)
  totalBlasts Int           @default(0)
  totalClicks Int           @default(0)

  // Calendar v2: Key dates for listings
  goLiveDate      DateTime? // When listing goes active
  nextOpenHouseAt DateTime? // Next scheduled open house

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  marketingBlasts MarketingBlast[]
  mlsImports      MlsListing[]
  tasks           Task[]
  landingPages    LandingPage[]
  leads           Lead[]
  pageViews       PageView[]
  leadActivities  LeadActivity[]
  savedListings   SavedListing[]

  @@index([agentId, status])
  @@index([agentId, createdAt])
  @@index([agentId, status, createdAt], map: "Listing_agentId_status_createdAt_idx")
  @@index([agentId, isFeatured, status], map: "Listing_agentId_isFeatured_status_idx")
}

enum ListingStatus {
  DRAFT
  ACTIVE
  ACTIVE_NO_SHOW
  PENDING
  UNDER_CONTRACT
  BACKUP
  SOLD
  WITHDRAWN
  CANCELED
  EXPIRED
  OFF_MARKET
}

model MarketingBlast {
  id           String                 @id @default(cuid())
  agentId      String
  agent        Agent                  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  listingId    String?
  listing      Listing?               @relation(fields: [listingId], references: [id])
  title        String
  playbook     BlastPlaybook          @default(NEW_LISTING)
  status       BlastStatus            @default(DRAFT)
  scheduledAt  DateTime?
  sentAt       DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @default(now()) @updatedAt
  channels     BlastChannel[]
  deliveryLogs MarketingDeliveryLog[]
  emailEvents  MarketingEmailEvent[]
  tasks        Task[]

  @@index([agentId, status])
  @@index([agentId, scheduledAt])
  @@index([agentId, sentAt])
  @@index([agentId, createdAt])
}

model BlastChannel {
  id           String                 @id @default(cuid())
  blastId      String
  blast        MarketingBlast         @relation(fields: [blastId], references: [id], onDelete: Cascade)
  channel      BlastChannelType
  enabled      Boolean                @default(true)
  status       BlastStatus            @default(DRAFT)
  previewText  String?
  previewHtml  String?
  shortCode    String?                @unique
  shortUrl     String?
  externalId   String?
  clicks       Int                    @default(0)
  uniqueClicks Int                    @default(0)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  hits         BlastHit[]
  deliveryLogs MarketingDeliveryLog[]
  emailEvents  MarketingEmailEvent[]

  @@index([blastId])
}

model BlastHit {
  id         String       @id @default(cuid())
  channelId  String
  channel    BlastChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  occurredAt DateTime     @default(now())
  ip         String?
  userAgent  String?

  @@index([channelId])
}

model MarketingDeliveryLog {
  id               String         @id @default(cuid())
  agentId          String
  agent            Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  blastId          String
  blast            MarketingBlast @relation(fields: [blastId], references: [id], onDelete: Cascade)
  channelId        String?
  channel          BlastChannel?  @relation(fields: [channelId], references: [id])
  provider         String         @default("sendgrid")
  status           String // SENT | FAILED
  messageId        String?
  subject          String
  recipientsCount  Int            @default(0)
  recipientsSample String[]       @default([])
  audienceType     String? // CLIENTS | LEADS | DEALS
  error            String?
  createdAt        DateTime       @default(now())

  @@index([agentId, createdAt])
  @@index([agentId, status, createdAt], map: "MarketingDeliveryLog_agentId_status_createdAt_idx")
  @@index([agentId, blastId, createdAt], map: "MarketingDeliveryLog_agentId_blastId_createdAt_idx")
  @@index([blastId, createdAt])
  @@index([channelId, createdAt])
  @@index([status, createdAt])
}

model MarketingEmailEvent {
  id         String   @id @default(cuid())
  provider   String   @default("sendgrid")
  eventType  String
  email      String?
  messageId  String?
  url        String?
  ip         String?
  userAgent  String?
  occurredAt DateTime
  meta       Json?

  agentId   String?
  agent     Agent?          @relation(fields: [agentId], references: [id], onDelete: SetNull)
  blastId   String?
  blast     MarketingBlast? @relation(fields: [blastId], references: [id], onDelete: SetNull)
  channelId String?
  channel   BlastChannel?   @relation(fields: [channelId], references: [id])

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([agentId, occurredAt])
  @@index([agentId, eventType, occurredAt], map: "MarketingEmailEvent_agentId_eventType_occurredAt_idx")
  @@index([agentId, blastId, occurredAt], map: "MarketingEmailEvent_agentId_blastId_occurredAt_idx")
  @@index([agentId, email, occurredAt], map: "MarketingEmailEvent_agentId_email_occurredAt_idx")
  @@index([blastId, occurredAt])
  @@index([channelId, occurredAt])
  @@index([eventType, occurredAt])
  @@index([messageId])
  @@index([messageId, eventType], map: "MarketingEmailEvent_messageId_eventType_idx")
}

enum BlastPlaybook {
  NEW_LISTING
  PRICE_REDUCTION
  OPEN_HOUSE
  UNDER_CONTRACT
  JUST_SOLD
  CUSTOM
}

enum BlastChannelType {
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  X
  EMAIL
  SMS
  WEBSITE
}

enum BlastStatus {
  DRAFT
  SCHEDULED
  SENT
}

model SignatureEnvelope {
  id                 String                @id @default(uuid())
  agentId            String?
  dealId             String?
  deal               Deal?                 @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type               SignatureEnvelopeType
  documentVersion    Int
  contractSnapshot   Json
  documentName       String?
  documentMimeType   String?
  documentData       Bytes?
  createdAt          DateTime              @default(now())
  lastReminderSentAt DateTime?
  completedAt        DateTime?
  signers            Signer[]
  audits             ESignAudit[]

  @@index([agentId])
  @@index([agentId, createdAt], map: "SignatureEnvelope_agentId_createdAt_idx")
  @@index([agentId, completedAt], map: "SignatureEnvelope_agentId_completedAt_idx")
  @@index([dealId])
  @@index([dealId, createdAt], map: "SignatureEnvelope_dealId_createdAt_idx")
  @@index([type, createdAt], map: "SignatureEnvelope_type_createdAt_idx")
}

enum SignatureEnvelopeType {
  REPC
  ADDENDUM
  DOCUMENT
}

model Signer {
  id            String            @id @default(uuid())
  envelopeId    String
  envelope      SignatureEnvelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  role          SignerRole
  name          String
  email         String
  viewedAt      DateTime?
  signedAt      DateTime?
  signatureType SignatureType     @default(NONE)
  ipAddress     String?
  userAgent     String?
  signatureData Json?
  auditHash     String?

  @@index([envelopeId])
  @@index([envelopeId, role], map: "Signer_envelopeId_role_idx")
  @@index([envelopeId, signedAt], map: "Signer_envelopeId_signedAt_idx")
  @@index([email], map: "Signer_email_idx")
}

enum SignerRole {
  BUYER
  SELLER
  AGENT
  OTHER
}

enum SignatureType {
  TYPED
  DRAWN
  UPLOADED
  NONE
}

model FormDefinition {
  id              String         @id @default(cuid())
  code            String         @unique
  displayName     String
  category        String
  version         String
  isActive        Boolean        @default(true)
  officialPdfPath String
  schemaJson      Json
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  formInstances   FormInstance[]
}

model FormInstance {
  id               String   @id @default(cuid())
  dealId           String
  formDefinitionId String
  status           String   @default("DRAFT")
  title            String
  data             Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  deal       Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  definition FormDefinition @relation(fields: [formDefinitionId], references: [id])

  @@index([dealId])
  @@index([formDefinitionId])
}

model DealEvent {
  id          String           @id @default(cuid())
  agentId     String
  agent       Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  dealId      String
  deal        Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type        DealEventType
  title       String
  description String?
  date        DateTime
  createdFrom EventCreatedFrom @default(MANUAL)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([agentId, dealId])
  @@index([agentId, date])
  @@index([agentId, createdAt])
}

enum DealEventType {
  SELLER_DISCLOSURE_DEADLINE
  DUE_DILIGENCE_DEADLINE
  FINANCING_DEADLINE
  APPRAISAL_DEADLINE
  SETTLEMENT_DEADLINE
  POSSESSION
  OTHER
}

enum EventCreatedFrom {
  REPC
  ADDENDUM
  MANUAL
}

model Task {
  id          String       @id @default(cuid())
  agentId     String
  agent       Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    TaskCategory @default(GENERAL)
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(NORMAL)
  bucket      TaskBucket   @default(TODAY)
  dueAt       DateTime?

  // Optional relationships
  dealId           String?
  deal             Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)
  clientId         String?
  client           Client?         @relation("ClientTasks", fields: [clientId], references: [id], onDelete: SetNull)
  listingId        String?
  listing          Listing?        @relation(fields: [listingId], references: [id], onDelete: SetNull)
  marketingBlastId String?
  marketingBlast   MarketingBlast? @relation(fields: [marketingBlastId], references: [id], onDelete: SetNull)

  createdFrom TaskCreatedFrom @default(MANUAL)

  // Recurrence support
  isRecurring     Boolean   @default(false)
  recurrenceRule  String? // RRULE format (e.g., "FREQ=MONTHLY;INTERVAL=1")
  recurrenceEndAt DateTime? // When recurrence stops
  parentTaskId    String? // Links to the original recurring task template

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId, status])
  @@index([agentId, dueAt])
  @@index([agentId, createdAt])
}

enum TaskCategory {
  GENERAL
  CONTRACT
  MARKETING
  CALL
  NOTE
  POPBY
  EVENT
}

model MlsListing {
  id            String   @id @default(cuid())
  agentId       String
