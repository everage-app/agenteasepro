  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  activityType String
  listingId    String?
  listing      Listing? @relation(fields: [listingId], references: [id])
  description  String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([leadId])
  @@index([leadId, createdAt], map: "LeadActivity_leadId_createdAt_idx")
  @@index([listingId, createdAt], map: "LeadActivity_listingId_createdAt_idx")
  @@index([createdAt])
}

model Client {
