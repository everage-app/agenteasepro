model Lead {
  id             String           @id @default(cuid())
  agentId        String
  agent          Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?          @relation(fields: [clientId], references: [id])
  listingId      String?
  listing        Listing?         @relation(fields: [listingId], references: [id])
  landingPageId  String?
  landingPage    LandingPage?     @relation(fields: [landingPageId], references: [id])
  firstName      String
  lastName       String
  email          String
  phone          String?
  mailingAddress String?
  mailingCity    String?
  mailingState   String?
  mailingZip     String?
  source         LeadSource       @default(WEBSITE)
  priority       LeadPriority     @default(WARM)
  averagePrice   Int?
  homesViewed    Int              @default(0)
  lastVisit      DateTime?
  visitCount     Int              @default(0)
  lastContact    DateTime?
  nextTask       String?
  assignedTo     String?
  notes          String?
  tags           String[]         @default([])
  converted      Boolean          @default(false)
  convertedAt    DateTime?
  deletedAt      DateTime? // Soft delete
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  activities     LeadActivity[]
  savedListings  SavedListing[]
  searchCriteria SearchCriteria[]
  teamId         String?
  team           Team?            @relation(fields: [teamId], references: [id])
  brokerageId    String?
  brokerage      Brokerage?       @relation(fields: [brokerageId], references: [id])
  leadSlaId      String?
  leadSla        LeadSLA?         @relation(fields: [leadSlaId], references: [id])

  @@unique([agentId, email])
  @@index([agentId])
  @@index([agentId, createdAt], map: "Lead_agentId_createdAt_idx")
  @@index([agentId, source, createdAt], map: "Lead_agentId_source_createdAt_idx")
  @@index([agentId, priority, createdAt], map: "Lead_agentId_priority_createdAt_idx")
  @@index([agentId, converted, createdAt], map: "Lead_agentId_converted_createdAt_idx")
  @@index([agentId, landingPageId, createdAt], map: "Lead_agentId_landingPageId_createdAt_idx")
  @@index([listingId])
  @@index([landingPageId])
  @@index([email])
  @@index([createdAt])
  @@index([agentId, deletedAt])
  @@index([teamId, createdAt], map: "Lead_teamId_createdAt_idx")
  @@index([brokerageId, createdAt], map: "Lead_brokerageId_createdAt_idx")
}

model LeadActivity {
  id           String   @id @default(cuid())
