}

model RoutingRule {
  id        String       @id @default(cuid())
  groupId   String
  group     RoutingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name      String
  priority  Int          @default(0)
  criteria  Json?
  assignTo  String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([groupId])
}

model LeadSLA {
  id              String   @id @default(cuid())
  teamId          String?
  team            Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  minutesToAccept Int      @default(15)
  warningMinutes  Int      @default(10)
  escalateToId    String?
  breachAction    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  leads           Lead[]

  @@index([teamId])
}

model WebhookSubscription {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  url       String
  events    String[] // Array of event names like "deal.created", "signature.completed"
  secret    String? // HMAC signing secret
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId, isActive])
}

model ESignAudit {
  id              String            @id @default(cuid())
  envelopeId      String
  envelope        SignatureEnvelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  action          String // E.g., 'CREATED', 'SENT', 'VIEWED', 'SIGNED', 'COMPLETED'
  actorIdentifier String? // e.g., Agent UUID or Signer Email
  ipAddress       String?
  userAgent       String?
  geoDetail       String?
  hash            String? // PGP or SHA256 hash or simulated audit
  timestamp       DateTime          @default(now())

  @@index([envelopeId, timestamp])
}

model SmartList {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])
  name      String
  icon      String?
  filters   Json // Dynamic filters structure (e.g., status, notes count, tags)
  sortOrder Json? // Config for sorting (e.g., {"field": "lastActivityAt", "direction": "desc"})
  isSystem  Boolean  @default(false) // e.g., "All Leads", "Hot Listings" (cannot be deleted)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId, name])
}
