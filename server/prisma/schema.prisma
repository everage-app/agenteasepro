// ==================== TEAM / BROKERAGE / RBAC ====================

enum TeamRole {
  OWNER
  MANAGER
  AGENT
  COORDINATOR
  VIEWER
}

model Team {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  brokerageName    String?
  brokerageLicense String?
  logoUrl          String?
  brandColor       String            @default("#3B82F6")
  timezone         String            @default("America/Denver")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  members          TeamMember[]
  leadRoutingRules LeadRoutingRule[]
  invitations      TeamInvitation[]
  deals            Deal[]
  leads            Lead[]
  primaryAgents    Agent[]           @relation("AgentPrimaryTeam")
  routingGroups    RoutingGroup[]
  leadSLAs         LeadSLA[]
  brokerageId      String?
  brokerage        Brokerage?        @relation(fields: [brokerageId], references: [id])

  @@index([slug])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  role      TeamRole @default(AGENT)
  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, agentId])
  @@index([agentId])
  @@index([teamId, role])
}

model TeamInvitation {
  id         String    @id @default(cuid())
  teamId     String
  team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  email      String
  role       TeamRole  @default(AGENT)
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([teamId])
  @@index([email])
  @@index([token])
}

// ==================== LEAD ROUTING & DISTRIBUTION ====================

enum LeadRoutingStrategy {
  ROUND_ROBIN
  WEIGHTED
  ZIP_CODE
  PRICE_RANGE
  SOURCE_BASED
  MANUAL
}

model LeadRoutingRule {
  id           String              @id @default(cuid())
  teamId       String
  team         Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name         String
  strategy     LeadRoutingStrategy @default(ROUND_ROBIN)
  isActive     Boolean             @default(true)
  priority     Int                 @default(0) // Higher = checked first
  conditions   Json? // e.g., { zipCodes: ["84101"], sources: ["ZILLOW"], priceMin: 200000 }
  assigneeIds  String[]            @default([]) // Agent IDs in rotation pool
  currentIndex Int                 @default(0) // For round-robin pointer
  weights      Json? // e.g., { "agentId1": 60, "agentId2": 40 }
  slaMinutes   Int? // Max minutes before escalation
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([teamId, isActive])
}

// ==================== SECURITY: DB-BACKED TOKEN REVOCATION & LOCKOUT ====================

model RevokedToken {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  jti       String   @unique // JWT token ID
  expiresAt DateTime // When the original token would have expired
  revokedAt DateTime @default(now())

  @@index([jti])
  @@index([expiresAt])
}

model LoginAttemptRecord {
  id          String    @id @default(cuid())
  agentId     String?
  agent       Agent?    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  email       String
  ipAddress   String?
  userAgent   String?
  success     Boolean
  lockedUntil DateTime?
  createdAt   DateTime  @default(now())

  @@index([email, createdAt])
  @@index([email, lockedUntil], map: "LoginAttemptRecord_email_lockedUntil_idx")
  @@index([ipAddress, createdAt], map: "LoginAttemptRecord_ipAddress_createdAt_idx")
  @@index([agentId, createdAt])
}

model OAuthState {
  id        String   @id @default(cuid())
  state     String   @unique
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  provider  String // e.g., "google", "microsoft"
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([state])
  @@index([expiresAt])
}

// ==================== DISTRIBUTED LOCKS ====================

model DistributedLock {
  id        String   @id
  lockedBy  String // Instance identifier
  lockedAt  DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt], map: "DistributedLock_expiresAt_idx")
}

// ==================== EMAIL / SMS SEQUENCES (Drip Campaigns) ====================

enum SequenceStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum SequenceStepType {
  EMAIL
  SMS
  TASK
  WAIT
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  UNSUBSCRIBED
  BOUNCED
}

model Sequence {
  id                String               @id @default(cuid())
  agentId           String
  agent             Agent                @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  status            SequenceStatus       @default(DRAFT)
  triggerType       String? // e.g., "LEAD_CREATED", "CLIENT_STAGE_CHANGED", "MANUAL"
  triggerConditions Json? // e.g., { source: "WEBSITE", priority: "HOT" }
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  steps             SequenceStep[]
  enrollments       SequenceEnrollment[]

  @@index([agentId, status])
}

model SequenceStep {
  id           String           @id @default(cuid())
  sequenceId   String
  sequence     Sequence         @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepOrder    Int
  type         SequenceStepType
  delayMinutes Int              @default(0) // Delay from previous step
  subject      String? // For EMAIL type
  body         String? // Template body with {{merge_tags}}
  taskTitle    String? // For TASK type
  meta         Json? // Additional config per step type
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([sequenceId, stepOrder])
  @@index([sequenceId])
}

model SequenceEnrollment {
  id               String           @id @default(cuid())
  sequenceId       String
  sequence         Sequence         @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  agentId          String
  agent            Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  contactType      String // "LEAD" | "CLIENT"
  contactId        String // Lead or Client ID
  status           EnrollmentStatus @default(ACTIVE)
  currentStepOrder Int              @default(0)
  nextStepAt       DateTime?
  completedAt      DateTime?
  unsubscribedAt   DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([sequenceId, status])
  @@index([agentId])
  @@index([agentId, status], map: "SequenceEnrollment_agentId_status_idx")
  @@index([nextStepAt, status])
  @@index([contactType, contactId])
}

// ==================== TRANSACTION CHECKLISTS ====================

enum ChecklistType {
